# HELP inference_requests_in_flight Requests currently dispatched to a backend and not yet settled.
# TYPE inference_requests_in_flight gauge
inference_requests_in_flight{backend="mock"} 0
# HELP inference_requests_total Requests by terminal outcome, incremented once per request at settle time (error_class="none" for successes).
# TYPE inference_requests_total counter
inference_requests_total{model="mock-8b",backend="mock",tenant_tier="default",status_class="2xx",error_class="none"} 2
# HELP inference_retries_total Upstream retries; stage has exactly one legal value, pre_first_token (0 until the retry budget lands, IG-T013).
# TYPE inference_retries_total counter
inference_retries_total{stage="pre_first_token"} 0
# HELP inference_sheds_total Admission rejections by reason (0 until admission control lands, IG-T010).
# TYPE inference_sheds_total counter
inference_sheds_total{reason="backend_unavailable"} 0
inference_sheds_total{reason="global_overload"} 0
inference_sheds_total{reason="queue_full"} 0
inference_sheds_total{reason="tenant_rate_limit"} 0
