# HELP inference_itl_seconds Inter-chunk gap between consecutive content-bearing stream chunks, measured at the gateway on upstream reads.
# TYPE inference_itl_seconds histogram
# HELP inference_queue_depth Admission queue depth per tenant tier (0 until admission control lands, IG-T010).
# TYPE inference_queue_depth gauge
inference_queue_depth{tenant_tier="default"} 0
